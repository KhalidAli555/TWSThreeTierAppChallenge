apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: three-tier
  labels:
    app: frontend
    env: demo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
    spec:
      containers:
      - name: frontend
        image: khalidali07/tws-frontend-threetier:02
        imagePullPolicy: Always
        env:
          - name: REACT_APP_BACKEND_URL
            value: "http:/:30007/api/tasks" # internal cluster URL
        ports:
        - containerPort: 3000
